{
  "manifest_version": 3,
  "name": "Caveman Web",
  "short_name": "Caveman",
  "version": "0.2.0",
  "description": "Ask AI chat sites to respond in terse Caveman-style prose. Local only.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.mistral.ai/*",
    "https://lechat.mistral.ai/*",
    "https://chat.qwen.ai/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://poe.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "action": {
    "default_title": "Caveman Web",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://lechat.mistral.ai/*",
        "https://chat.qwen.ai/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*"
      ],
      "js": [
        "src/shared/browser-polyfill.js",
        "src/shared/defaults.js",
        "src/shared/token-estimator.js",
        "src/shared/prompt-builder.js",
        "src/shared/storage.js",
        "src/content/dom-utils.js",
        "src/content/site-adapters.js",
        "src/content/badge.js",
        "src/content/content-script.js"
      ],
      "css": ["src/content/badge.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "caveman-web@example.org",
      "strict_min_version": "121.0"
    }
  }
}
